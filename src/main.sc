require: slotfilling/slotFilling.sc
module = sys.zb-common
theme: /

    state: Start
        q!: $regex</start>
        a: Привет! Я бот-помощник. Могу рассказать о погоде или курсе валют.

    state: hello
        q!: * привет *
        q!: * здравствуй *
        q!: * здравствуйте *
        q!: * добрый день *
        q!: * добрый вечер *
        q!: * доброе утро *
        q!: * хай *
        q!: * hello *
        q!: * start *
        q!: * начать *
        a: Привет! Я бот-помощник. Могу рассказать о погоде или курсе валют.

    state: weather
        q!: * погод *
        q!: * прогноз погод *
        q!: * температура *
        q!: * дожд *
        q!: * снег *
        q!: * ветер *
        q!: * тепло *
        q!: * холодно *
        q!: * какая погода *
        q!: * погода сегодня *
        q!: * weather *
        a: Сейчас я могу обработать запрос о погоде. Для точного прогноза укажите город.

    state: currency
        q!: * курс *
        q!: * валют *
        q!: * доллар *
        q!: * доллары *
        q!: * евро *
        q!: * рубль *
        q!: * рубли *
        q!: * юань *
        q!: * currency *
        q!: * exchange *
        a: Сейчас я могу обработать запрос курса валют. Например, можно спросить курс доллара или евро.

    state: NoMatch
        event!: noMatch
        q!: *
        a: Я не понял запрос. Попробуйте спросить о погоде или курсе валют.